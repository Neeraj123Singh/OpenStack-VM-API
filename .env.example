# Application
OPENSTACK_MODE=mock
# OPENSTACK_MODE=real

# When using real OpenStack, export standard credentials (example):
# OS_AUTH_URL=https://controller:5000/v3
# OS_PROJECT_NAME=demo
# OS_USERNAME=demo
# OS_PASSWORD=secret
# OS_USER_DOMAIN_NAME=Default
# OS_PROJECT_DOMAIN_NAME=Default
# OS_IDENTITY_API_VERSION=3
# OS_INTERFACE=public

# Optional: pin SDK to a project UUID
# OPENSTACK_PROJECT_ID=

DEBUG=false
